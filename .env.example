# Dán trong Vercel → Project → Settings → Environment Variables
USEAPI_TOKEN=user:YOUR_USEAPI_TOKEN_HERE

# Để trống USEAPI_EMAIL khi đã thêm nhiều tài khoản Google Flow vào useapi.net.
# useapi.net sẽ tự cân bằng tải giữa các tài khoản đủ điều kiện.
USEAPI_EMAIL=

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# Supabase dùng cho đăng nhập, credit, lịch sử, thanh toán và lưu video dài hạn.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VIDEO_STORAGE_BUCKET=generated-videos

# Stripe Checkout và webhook.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
# Giá theo đơn vị nhỏ nhất của tiền tệ. USD: 990 = 9.90 USD. VND: 99000 = 99.000 VND.
STRIPE_STARTER_AMOUNT=990
STRIPE_PRO_AMOUNT=2490
STRIPE_BUSINESS_AMOUNT=5990

# Chuỗi ngẫu nhiên tối thiểu 16 ký tự. Vercel tự gửi dưới dạng Authorization: Bearer ...
CRON_SECRET=replace_with_a_long_random_secret
