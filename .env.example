# Google Flow qua useapi.net
USEAPI_TOKEN=user:YOUR_USEAPI_TOKEN_HERE
# Để trống để useapi.net tự cân bằng nhiều tài khoản Flow.
USEAPI_EMAIL=

# DeepSeek viết kịch bản
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash

APP_URL=https://TEN-MIEN-CUA-BAN.com

# Supabase Auth, Database và Storage
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
VIDEO_STORAGE_BUCKET=generated-videos

# Stripe Checkout
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd
# Đơn vị nhỏ nhất: USD cents; VND dùng số nguyên đồng.
STRIPE_STARTER_AMOUNT=990
STRIPE_PRO_AMOUNT=2490
STRIPE_BUSINESS_AMOUNT=5990

# Vercel Cron hoặc dịch vụ cron ngoài
CRON_SECRET=replace_with_a_long_random_secret

# Bổ sung domain video nguồn, phân cách dấu phẩy nếu useapi trả URL từ host khác.
VIDEO_SOURCE_HOSTS=.googleusercontent.com,.googlevideo.com,.useapi.net,.supabase.co,storage.googleapis.com
