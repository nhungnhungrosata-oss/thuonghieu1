# Dán trong Vercel → Project → Settings → Environment Variables
USEAPI_TOKEN=user:YOUR_USEAPI_TOKEN_HERE

# Để trống USEAPI_EMAIL khi đã thêm nhiều tài khoản Google Flow vào useapi.net.
# useapi.net sẽ tự cân bằng tải giữa các tài khoản đủ điều kiện.
USEAPI_EMAIL=

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash

# Supabase dùng cho đăng nhập, credit, lịch sử và cô lập job theo từng khách hàng.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
